FROM node:22-bullseye-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app \
    CODEX_HOME=/tmp/.codex \
    CLOUDSDK_CORE_DISABLE_PROMPTS=1

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl gnupg git python3 python3-pip \
    && mkdir -p /etc/apt/keyrings \
    && curl -fsSL https://packages.cloud.google.com/apt/doc/apt-key.gpg \
       | gpg --dearmor -o /etc/apt/keyrings/google-cloud.gpg \
    && echo 'deb [signed-by=/etc/apt/keyrings/google-cloud.gpg] https://packages.cloud.google.com/apt cloud-sdk main' \
       > /etc/apt/sources.list.d/google-cloud-sdk.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends google-cloud-cli \
    && npm install -g @openai/codex \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt ./requirements.txt
COPY requirements-dev.txt ./requirements-dev.txt

RUN python3 -m pip install --no-cache-dir --upgrade pip \
    && python3 -m pip install --no-cache-dir -r requirements.txt

COPY src/ ./src/
COPY vendor/ ./vendor/
COPY bin/codex_shadow_entrypoint.sh ./bin/codex_shadow_entrypoint.sh

RUN useradd --create-home --home-dir /home/appuser --shell /usr/sbin/nologin appuser \
    && mkdir -p /app/logs /app/data /tmp/.codex \
    && chmod +x /app/bin/codex_shadow_entrypoint.sh \
    && chown -R appuser:appuser /app /home/appuser /tmp/.codex

USER appuser

ENTRYPOINT ["/app/bin/codex_shadow_entrypoint.sh"]
CMD ["--provider", "codex", "--max-posts", "3"]
